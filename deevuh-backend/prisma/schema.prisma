datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
}

enum CartStatus {
  active
  abandoned
  converted
}

enum PaymentMethod {
  ONLINE
  COD
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  BOOKING_RECEIVED
  REFUNDED
}

enum OrderStatus {
  CREATED
  CONFIRMED
  PROCESSING
  PACKED
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURNED
}

model User {
  id              String   @id @default(uuid()) @db.Uuid
  name            String   @db.VarChar(255)
  email           String   @unique @db.VarChar(255)
  phone           String?  @db.VarChar(50)
  password        String?  @db.Text
  googleId        String?  @unique @map("google_id")
  authProvider    String   @default("LOCAL") @map("auth_provider")
  avatar          String?  @db.Text
  tokenVersion    Int      @default(0) @map("token_version")
  isEmailVerified Boolean  @default(false) @map("is_email_verified")
  carts           Cart[]
  orders          Order[]
  reviews         Review[]
  customerRisk    CustomerRisk?
  chest           String?  @db.VarChar(50)
  waist           String?  @db.VarChar(50)
  shoulder        String?  @db.VarChar(50)
  height          String?  @db.VarChar(50)
  fit             String?  @db.VarChar(100)
  wishlist        WishlistItem[]
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("users")
}

model Product {
  id          String           @id @default(uuid()) @db.Uuid
  title       String           @db.VarChar(255)
  description String           @db.Text
  basePrice   Decimal          @map("base_price") @db.Decimal(10, 2)
  category    String           @db.VarChar(100)
  isActive    Boolean          @default(true) @map("is_active")
  variants    ProductVariant[]
  images      ProductImage[]
  reviews     Review[]
  wishlistedBy WishlistItem[]
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @default(now()) @updatedAt @map("updated_at")

  @@index([category])
  @@map("products")
}

model ProductVariant {
  id         String      @id @default(uuid()) @db.Uuid
  productId  String      @map("product_id") @db.Uuid
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  size       String      @db.VarChar(50)
  price      Decimal     @db.Decimal(10, 2)
  stockQty   Int         @map("stock_qty")
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([productId])
  @@map("product_variants")
}

model ProductImage {
  id        String  @id @default(uuid()) @db.Uuid
  productId String  @map("product_id") @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  imageUrl  String  @map("image_url") @db.Text
  order     Int     @default(0) @map("order") @db.Integer

  @@index([productId])
  @@map("product_images")
}

model Cart {
  id             String     @id @default(uuid()) @db.Uuid
  userId         String?    @map("user_id") @db.Uuid
  user           User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  status         CartStatus @default(active)
  lastActivityAt DateTime   @updatedAt @map("last_activity_at")
  items          CartItem[]

  @@index([userId, status])
  @@map("carts")
}

model CartItem {
  id               String         @id @default(uuid()) @db.Uuid
  cartId           String         @map("cart_id") @db.Uuid
  cart             Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productVariantId String         @map("product_variant_id") @db.Uuid
  variant          ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Restrict)
  quantity         Int

  @@index([cartId])
  @@index([productVariantId])
  @@map("cart_items")
}

model Order {
  id                    String         @id @default(uuid()) @db.Uuid
  userId                String?        @map("user_id") @db.Uuid
  user                  User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  shippingAddress       String         @map("shipping_address") @db.Text
  shippingName          String         @map("shipping_name") @db.VarChar(255)
  shippingPhone         String         @map("shipping_phone") @db.VarChar(50)
  couponId              String?        @map("coupon_id") @db.Uuid
  coupon                Coupon?        @relation(fields: [couponId], references: [id], onDelete: Restrict)
  totalAmount           Decimal        @map("total_amount") @db.Decimal(10, 2)
  discountAmount        Decimal        @default(0.00) @map("discount_amount") @db.Decimal(10, 2)
  gstAmount             Decimal        @default(0.00) @map("gst_amount") @db.Decimal(10, 2)
  finalAmount           Decimal        @map("final_amount") @db.Decimal(10, 2)
  paymentGatewayTxnId   String?        @unique @map("payment_gateway_txn_id") @db.VarChar(255)
  paymentMethod         PaymentMethod  @default(ONLINE) @map("payment_method")
  paymentStatus         PaymentStatus  @default(PENDING) @map("payment_status")
  orderStatus           OrderStatus    @default(CREATED) @map("order_status")
  isCOD                 Boolean        @default(false) @map("is_cod")
  codEligible           Boolean?       @map("cod_eligible")
  bookingAmount         Decimal?       @map("booking_amount") @db.Decimal(10, 2)
  remainingCODAmount    Decimal?       @map("remaining_cod_amount") @db.Decimal(10, 2)
  bookingPaymentTxnId   String?        @map("booking_payment_txn_id") @db.VarChar(255)
  codConfirmedAt        DateTime?      @map("cod_confirmed_at")
  stockReserved         Boolean        @default(false) @map("stock_reserved")
  items                 OrderItem[]
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @default(now()) @updatedAt @map("updated_at")

  @@index([userId])
  @@index([paymentStatus, orderStatus])
  @@index([paymentMethod])
  @@map("orders")
}

model OrderItem {
  id               String         @id @default(uuid()) @db.Uuid
  orderId          String         @map("order_id") @db.Uuid
  order            Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariantId String         @map("product_variant_id") @db.Uuid
  variant          ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Restrict)
  quantity         Int
  unitPrice        Decimal        @map("unit_price") @db.Decimal(10, 2)

  @@index([orderId])
  @@index([productVariantId])
  @@map("order_items")
}

model Coupon {
  id            String   @id @default(uuid()) @db.Uuid
  code          String   @unique @db.VarChar(50)
  discountType  String   @map("discount_type") @db.VarChar(20)
  discountValue Decimal  @map("discount_value") @db.Decimal(10, 2)
  minPurchase   Decimal? @map("min_purchase") @db.Decimal(10, 2)
  maxUses       Int?     @map("max_uses")
  usedCount     Int      @default(0) @map("used_count")
  isActive      Boolean  @default(true) @map("is_active")
  expiresAt     DateTime @map("expires_at")
  orders        Order[]
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("coupons")
}

model AdminUser {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.Text
  role         String   @default("ADMIN") @db.VarChar(50)
  tokenVersion Int      @default(0) @map("token_version")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("admin_users")
}

model EmailVerificationToken {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @db.VarChar(255)
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @db.VarChar(255)
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@map("password_reset_tokens")
}

model AuthLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String   @db.VarChar(50)
  ip        String?  @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("auth_logs")
}

model Review {
  id               String        @id @default(uuid()) @db.Uuid
  productId        String        @map("product_id") @db.Uuid
  product          Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId           String        @map("user_id") @db.Uuid
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating           Int           @db.Integer
  title            String?       @db.VarChar(255)
  reviewText       String        @map("review_text") @db.Text
  verifiedPurchase Boolean       @default(false) @map("verified_purchase")
  isHidden         Boolean       @default(false) @map("is_hidden")
  images           ReviewImage[]
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  @@unique([productId, userId], name: "product_user_unique")
  @@index([userId])
  @@map("reviews")
}

model ReviewImage {
  id        String   @id @default(uuid()) @db.Uuid
  reviewId  String   @map("review_id") @db.Uuid
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  imageUrl  String   @map("image_url") @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@map("review_images")
}

model WishlistItem {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String   @map("product_id") @db.Uuid
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, productId], name: "user_product_unique")
  @@index([userId])
  @@map("wishlist_items")
}

model ProcessedWebhook {
  id        String   @id @default(uuid()) @db.Uuid
  webhookId String   @unique @map("webhook_id") @db.VarChar(255)
  paymentId String   @map("payment_id") @db.VarChar(255)
  status    String   @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([paymentId])
  @@map("processed_webhooks")
}

model SiteSettings {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique @db.VarChar(100)
  value     String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

model CustomerRisk {
  id                  String    @id @default(uuid()) @db.Uuid
  userId              String    @unique @map("user_id") @db.Uuid
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  cancellationCount   Int       @default(0) @map("cancellation_count")
  rtoCount            Int       @default(0) @map("rto_count")
  codOrderCount       Int       @default(0) @map("cod_order_count")
  isBlacklisted       Boolean   @default(false) @map("is_blacklisted")
  blacklistedAt       DateTime? @map("blacklisted_at")
  blacklistReason     String?   @map("blacklist_reason") @db.VarChar(255)
  riskScore           Int       @default(0) @map("risk_score")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@map("customer_risks")
}

model EmailLog {
  id              String    @id @default(uuid()) @db.Uuid
  orderId         String    @map("order_id") @db.Uuid
  emailType       String    @map("email_type") @db.VarChar(50)
  recipient       String    @db.VarChar(255)
  status          String    @db.VarChar(50)
  resendMessageId String?   @map("resend_message_id") @db.VarChar(255)
  retryCount      Int       @default(0) @map("retry_count")
  lastError       String?   @map("last_error") @db.Text
  sentAt          DateTime? @map("sent_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@unique([orderId, emailType], name: "order_email_unique")
  @@index([orderId])
  @@index([status])
  @@map("email_logs")
}


