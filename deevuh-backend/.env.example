# DEEVUH V3 — Environment Variables Reference
# Copy this file to .env and fill in all values before running the backend

# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# ─────────────────────────────────────────────
# RUNTIME
# ─────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ─────────────────────────────────────────────
# JWT AUTHENTICATION (REQUIRED — app crashes without these)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ─────────────────────────────────────────────
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# APPLICATION URLS
# ─────────────────────────────────────────────
FRONTEND_URL=https://yourdomain.com
BACKEND_URL=https://api.yourdomain.com
COOKIE_DOMAIN=.yourdomain.com

# ─────────────────────────────────────────────
# PAYMENT (PAYU)
# Get from: https://onboarding.payu.in/
# ─────────────────────────────────────────────
PAYU_MERCHANT_KEY=
PAYU_MERCHANT_SALT=
PAYU_ENVIRONMENT=production

# ─────────────────────────────────────────────
# CLOUDINARY (Image CDN)
# Get from: https://cloudinary.com/console
# ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─────────────────────────────────────────────
# GOOGLE OAUTH
# Get from: https://console.cloud.google.com/apis/credentials
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=

# ─────────────────────────────────────────────
# EMAIL (RESEND)
# Get from: https://resend.com/api-keys
# ─────────────────────────────────────────────
RESEND_API_KEY=

# ─────────────────────────────────────────────
# NOTIFICATIONS
# Email address that receives new order alerts
# ─────────────────────────────────────────────
OWNER_EMAIL=deevuhinfo@gmail.com
